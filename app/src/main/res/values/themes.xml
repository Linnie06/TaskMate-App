<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TaskMate_app" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Customize your theme here -->

        <!-- Status bar color (the top bar with time/battery) -->
        <item name="android:statusBarColor">?attr/colorPrimaryDark</item>

        <!-- Action bar background color -->
        <item name="actionBarStyle">@style/MyActionBar</item>

        <!-- Text appearance -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/purple_700</item>

        <!-- Background color for the app -->
        <item name="android:windowBackground">@color/white</item>

        <!-- CardView elevation and corner radius -->
        <item name="cardViewStyle">@style/MyCardView</item>
    </style>

    <!-- Dark theme variant -->
    <style name="Theme.TaskMate_app.Dark" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Primary brand color for dark theme -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryDark</item>

        <!-- Action bar background color -->
        <item name="actionBarStyle">@style/MyActionBar</item>

        <!-- Text appearance for dark theme -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/purple_200</item>

        <!-- Background color for dark theme -->
        <item name="android:windowBackground">#121212</item>

        <!-- CardView elevation and corner radius -->
        <item name="cardViewStyle">@style/MyCardView</item>
    </style>

    <!-- Custom ActionBar style -->
    <style name="MyActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">?attr/colorPrimary</item>
        <item name="titleTextStyle">@style/MyTitleTextStyle</item>
    </style>

    <!-- ActionBar title text style -->
    <style name="MyTitleTextStyle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- Custom Button style -->
    <style name="MyButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@color/colorAccent</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Custom CardView style -->
    <style name="MyCardView" parent="CardView">
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">8dp</item>
    </style>

    <!-- Dialog Button style -->
    <style name="DialogButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Main Activity Button style -->
    <style name="MainButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>