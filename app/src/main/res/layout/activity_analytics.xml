<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Task Analytics"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#7E00FD"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- Completion Status Chart -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Task Completion Status"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#673AB7"
                    android:gravity="center"
                    android:paddingBottom="8dp" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieCompleted"
                    android:layout_width="match_parent"
                    android:layout_height="250dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Priority Distribution Chart -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Priority Chart"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#673AB7"
                    android:gravity="center"
                    android:paddingBottom="8dp" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/piePriority"
                    android:layout_width="match_parent"
                    android:layout_height="250dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Task Statistics -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Quick Stats"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#673AB7"
                    android:gravity="center"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTotalTasks"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Total: 0"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="#E607C9"
                        android:textColor="@color/white"
                        android:padding="12dp"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/tvCompletionRate"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Rate: 0%"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:background="#1987E9"
                        android:textColor="@color/white"
                        android:padding="12dp"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
